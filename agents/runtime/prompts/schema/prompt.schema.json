{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentPrompt",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "prompt"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^ppm.prompts/v1$"
    },
    "kind": {
      "type": "string",
      "const": "Prompt"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "owner",
        "version",
        "agent",
        "purpose"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "prompt": {
      "type": "object",
      "required": [
        "system",
        "user"
      ],
      "properties": {
        "system": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redaction": {
          "type": "object",
          "required": [
            "pii",
            "secrets"
          ],
          "properties": {
            "pii": {
              "type": "boolean"
            },
            "secrets": {
              "type": "boolean"
            },
            "strategy": {
              "type": "string",
              "enum": [
                "mask",
                "drop"
              ],
              "default": "mask"
            },
            "fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
