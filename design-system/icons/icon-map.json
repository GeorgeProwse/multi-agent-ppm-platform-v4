{
  "name": "ppm-icons",
  "version": "1.0.0",
  "library": "lucide-react",
  "defaults": {
    "sizePx": {
      "sm": 14,
      "md": 18,
      "lg": 24
    },
    "colorTokens": {
      "primaryText": "tokens.color.text.primary",
      "brand": "tokens.color.brand.orange500",
      "accent": "tokens.color.brand.orange500",
      "neutral": "tokens.color.neutral.grey500",
      "success": "tokens.color.state.success.fg",
      "warning": "tokens.color.state.warning.fg",
      "error": "tokens.color.state.error.fg",
      "info": "tokens.color.state.info.fg"
    }
  },
  "rules": {
    "requireSemanticUsage": true
  },
  "categories": {
    "navigation": {
      "collapse": { "icon": "ChevronDown", "color": "primaryText", "size": "md" },
      "next": { "icon": "ChevronRight", "color": "primaryText", "size": "md" },
      "back": { "icon": "ArrowLeft", "color": "primaryText", "size": "md" },
      "forward": { "icon": "ArrowRight", "color": "primaryText", "size": "md" },
      "external": { "icon": "ExternalLink", "color": "primaryText", "size": "md" },
      "search": { "icon": "Search", "color": "primaryText", "size": "md" }
    },
    "actions": {
      "edit": { "icon": "Edit3", "color": "primaryText", "size": "md" },
      "confirmApply": { "icon": "Check", "color": "success", "size": "md" },
      "cancelDismiss": { "icon": "X", "color": "primaryText", "size": "md" },
      "help": { "icon": "HelpCircle", "color": "primaryText", "size": "md" },
      "settings": { "icon": "Settings", "color": "primaryText", "size": "md" },
      "download": { "icon": "Download", "color": "primaryText", "size": "md" },
      "refresh": { "icon": "RefreshCw", "color": "primaryText", "size": "md" },
      "more": { "icon": "MoreHorizontal", "color": "primaryText", "size": "md" },
      "undo": { "icon": "Undo2", "color": "primaryText", "size": "md" },
      "attach": { "icon": "Paperclip", "color": "primaryText", "size": "md" },
      "mic": { "icon": "Mic", "color": "primaryText", "size": "md" },
      "link": { "icon": "Link2", "color": "primaryText", "size": "md" },
      "preview": { "icon": "Eye", "color": "primaryText", "size": "md" }
    },
    "artifact": {
      "dashboard": { "icon": "LayoutDashboard", "color": "primaryText", "size": "md" },
      "document": { "icon": "FileText", "color": "primaryText", "size": "md" },
      "spreadsheet": { "icon": "Table", "color": "primaryText", "size": "md" },
      "timeline": { "icon": "Clock", "color": "primaryText", "size": "md" },
      "tree": { "icon": "GitBranch", "color": "primaryText", "size": "md" },
      "folder": { "icon": "Folder", "color": "primaryText", "size": "md" }
    },
    "communication": {
      "send": { "icon": "Send", "color": "brand", "size": "md" },
      "message": { "icon": "MessageSquare", "color": "primaryText", "size": "md" },
      "notifications": { "icon": "Bell", "color": "primaryText", "size": "md" },
      "assistant": { "icon": "Brain", "color": "brand", "size": "md" },
      "user": { "icon": "User", "color": "primaryText", "size": "md" }
    },
    "domain": {
      "platform": { "icon": "Rocket", "color": "brand", "size": "md" },
      "portfolio": { "icon": "Layers", "color": "primaryText", "size": "md" },
      "program": { "icon": "Package", "color": "primaryText", "size": "md" },
      "project": { "icon": "ClipboardList", "color": "primaryText", "size": "md" },
      "core": { "icon": "Cpu", "color": "primaryText", "size": "md" },
      "delivery": { "icon": "Rocket", "color": "primaryText", "size": "md" },
      "governance": { "icon": "Shield", "color": "primaryText", "size": "md" },
      "operations": { "icon": "Server", "color": "primaryText", "size": "md" }
    },
    "provenance": {
      "auditLog": { "icon": "History", "color": "primaryText", "size": "md" },
      "link": { "icon": "Link2", "color": "primaryText", "size": "md" }
    },
    "ai": {
      "explainability": { "icon": "Lightbulb", "color": "warning", "size": "md" },
      "automation": { "icon": "Sparkles", "color": "brand", "size": "md" },
      "suggestion": { "icon": "Sparkles", "color": "brand", "size": "md" }
    },
    "connectors": {
      "cpuChip": { "icon": "Cpu", "color": "primaryText", "size": "md" }
    },
    "status": {
      "healthy": { "icon": "CheckCircle", "color": "success", "size": "md" },
      "warning": { "icon": "AlertTriangle", "color": "warning", "size": "md" },
      "error": { "icon": "XCircle", "color": "error", "size": "md" },
      "info": { "icon": "Info", "color": "info", "size": "md" },
      "loading": { "icon": "Loader2", "color": "neutral", "size": "md", "animate": "spin" },
      "paused": { "icon": "PauseCircle", "color": "neutral", "size": "md" },
      "locked": { "icon": "Lock", "color": "neutral", "size": "md" },
      "unlocked": { "icon": "Unlock", "color": "success", "size": "md" },
      "blocked": { "icon": "Ban", "color": "error", "size": "md" }
    }
  }
}
